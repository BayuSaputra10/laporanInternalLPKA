generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model VehicleReport {
  id        Int      @id @default(autoincrement())

  jenisKendaraan String
  namaDriver     String
  keperluan      String
  tanggal        DateTime

  kmAwal         Float
  kmAkhir        Float

  kmPemakaian    Float?

  solarAwalStrip Float
  solarAkhirStrip Float

  solarPemakaian Float?

  fotoData Bytes?   // ✅ BASE64 / BINARY

  reportNumber String @unique @default(cuid())
  createdBy    String?
  status       String @default("draft")

  createdAt    DateTime @default(now())
}


model GensetReport {
  id        Int      @id @default(autoincrement())

  regu      String
  tanggal   DateTime

  waktuPemakaianJam Float
  hourMeterAwal     Float
  hourMeterAkhir    Float

  solarLevelAwal   Float
  solarLevelAkhir  Float

  solarPemakaian   Float?

  photoData Bytes?   // ✅ BALIK KE BASE64 STORAGE

  createdAt DateTime @default(now())

  inspections GensetInspection[]
}

model GensetInspection {
  id         Int @id @default(autoincrement())

  reportId   Int
  itemId     Int

  kondisi    String
  keterangan String?

  report GensetReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  item   InspectionItem @relation(fields: [itemId], references: [id])
}

model InspectionItem {
  id     Int    @id @default(autoincrement())
  name   String
  type   String

  inspections GensetInspection[]
}