generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


model VehicleReport {
  id        Int      @id @default(autoincrement())
  tanggal   DateTime
  unit      String?
  kmAwal    Int?
  kmAkhir   Int?
  solarAwal Float?
  solarAkhir Float?
  catatan   String?

  inspections VehicleInspection[]
}

model GensetReport {
  id        Int      @id @default(autoincrement())
  regu      String
  tanggal   DateTime
  mesin     String?
  generator String?
  shift     String?

  speed     Float?
  oliPress  Float?
  temp      Float?

  volt      Float?
  hz        Float?
  kw        Float?

  ampereR   Float?
  ampereS   Float?
  ampereT   Float?
  ampere    Float?

  solarLevelAwal   Float?
  solarLevelAkhir  Float?
  solarPemakaian   Float?

  gantiOliMesin    Float?
  gantiFilterOli   Float?
  gantiFilterSolar Float?

  catatan   String?

  inspections GensetInspection[]
}

model VehicleInspection {
  id         Int    @id @default(autoincrement())
  reportId   Int
  itemId     Int
  kondisi    String
  keterangan String?

  report VehicleReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  item   InspectionItem @relation(fields: [itemId], references: [id])
}

model GensetInspection {
  id         Int    @id @default(autoincrement())
  reportId   Int
  itemId     Int
  kondisi    String
  keterangan String?

  report GensetReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  item   InspectionItem @relation(fields: [itemId], references: [id])
}

model InspectionItem {
  id     Int    @id @default(autoincrement())
  name   String
  type   String // vehicle / genset

  vehicleInspections VehicleInspection[]
  gensetInspections  GensetInspection[]
}